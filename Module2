Sub Convert_ms()

    Dim lastcol As Long, Unit_rng As Range
    Dim Rng As Range

    Call initWS_data

    lastcol = ws_data.Cells(8, Columns.Count).End(xlToLeft).Column
    Debug.Print lastcol

    lastrow = ws_data.Cells(Rows.Count, lastcol).End(xlUp).Row
    Debug.Print lastrow

    Set Rng = ws_data.Range(ws_data.Cells(8, 2), ws_data.Cells(lastrow, lastcol))
    Set Unit_rng = ws_data.Range(ws_data.Cells(7, 2), ws_data.Cells(7, lastcol))

    Rng.Value = ws_data.Evaluate(Rng.Address & "*0.001")

    Unit_rng.Replace What:="mm/s^2", Replacement:="[m/s^2]", LookAt:=xlPart

    Sheets("Data").Select

End Sub
