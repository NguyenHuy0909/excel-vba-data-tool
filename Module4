Option Explicit
Public folderPath As String
Public ws_tool As Worksheet, ws_data As Worksheet
Public o_row As Long
Public flag As Long
Public firstcol As Long

Sub initWS_data()
    Set ws_data = ThisWorkbook.Sheets("Data")
    Set ws_tool = ThisWorkbook.Sheets("Tool")
End Sub


Sub ImportHeaderGID()

    Const HEADER_ROW As Long = 6
    Const FIRST_FILE_ROW As Long = 5

    Dim filepath As String
    Dim rowHeader As Long, lastRow As Long, rowIndex As Long
    Dim numOutput As Long
    Dim headerBuffers(1 To 2) As String
    Dim r As Long, c As Long

    Call initWS_data

    Application.ScreenUpdating = False

    firstcol = GetFirstOutputColumn()

    lastRow = ws_tool.Cells(ws_tool.Rows.Count, "Z").End(xlUp).Row
    numOutput = Application.WorksheetFunction.CountA(ws_tool.Range("AE1:AI1"))

    For rowIndex = FIRST_FILE_ROW To lastRow

        filepath = ThisWorkbook.Sheets("Tool").Range("Z" & rowIndex).Value

        If Not FileExists(filepath) Then
            MsgBox "Not found *.GID file path. Please check Load Folder Path", vbCritical
            Application.ScreenUpdating = True
            Exit Sub
        End If

        rowHeader = HEADER_ROW
        col_header = GetNextHeaderColumn(HEADER_ROW)

        ReadHeaderBuffers filepath, headerBuffers
        WriteHeaderBuffersToSheet headerBuffers, rowHeader

        Call ImportGID(filepath, r, c, rowHeader)

        col_header = col_header + numOutput

        Call result_filter
        Call result_filter

    Next rowIndex

    Call remove_duplicate_firstColumn
    Call addTitle

    Application.ScreenUpdating = True

    Sheets("Data").Select

End Sub

Private Function GetFirstOutputColumn() As Long

    Dim lastCol As Long

    If Application.WorksheetFunction.CountA(ws_data.Cells) = 0 Then
        flag = 0
    Else
        flag = 1
    End If

    lastCol = ws_data.Cells(6, ws_data.Columns.Count).End(xlToLeft).Column

    If flag = 0 Then
        GetFirstOutputColumn = 2
    Else
        GetFirstOutputColumn = lastCol + 1
    End If

End Function

Private Function GetNextHeaderColumn(ByVal headerRow As Long) As Long

    Dim lastCol As Long

    lastCol = ws_data.Cells(headerRow, ws_data.Columns.Count).End(xlToLeft).Column

    If lastCol = 1 Then
        GetNextHeaderColumn = 1
    Else
        GetNextHeaderColumn = lastCol + 1
    End If

End Function

Private Function FileExists(ByVal filepath As String) As Boolean

    Dim fso As Object

    Set fso = CreateObject("Scripting.FileSystemObject")
    FileExists = fso.fileexists(filepath)

End Function

Private Sub ReadHeaderBuffers(ByVal filepath As String, ByRef headerBuffers() As String)

    Dim fso As Object, ts As Object
    Dim currentLine As String

    headerBuffers(1) = ""
    headerBuffers(2) = ""

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    Do Until ts.AtEndOfStream

        currentLine = ts.ReadLine

        If InStr(1, currentLine, "CHANNEL", vbBinaryCompare) > 0 Then
            headerBuffers(1) = BuildHeaderLine(currentLine, ts)
            Debug.Print headerBuffers(1)
        ElseIf InStr(1, currentLine, "UNIT", vbBinaryCompare) > 0 Then
            headerBuffers(2) = BuildHeaderLine(currentLine, ts)
            Debug.Print headerBuffers(2)
        End If

    Loop

    ts.Close

End Sub

Private Function BuildHeaderLine(ByVal firstLine As String, ByVal textStream As Object) As String

    Dim combinedLine As String

    combinedLine = firstLine

    If Not textStream.AtEndOfStream Then
        combinedLine = combinedLine & textStream.ReadLine
    End If

    BuildHeaderLine = Replace(combinedLine, "&", "")

End Function

Private Sub WriteHeaderBuffersToSheet(ByRef headerBuffers() As String, ByRef rowHeader As Long)

    Dim r As Long, c As Long, i As Long
    Dim parts As Variant

    For r = 1 To 2
        If headerBuffers(r) <> "" Then
            parts = Split(headerBuffers(r), "'")
            c = col_header

            For i = 2 To UBound(parts) Step 2
                ws_data.Cells(rowHeader, c).Value = parts(i)
                c = c + 1
            Next i

            rowHeader = rowHeader + 1
        End If
    Next r

End Sub

Sub ImportGID(ByVal filepath As String, ByRef r As Long, ByRef c As Long, ByRef row_header As Long)

    Dim fso As Object, ts As Object
    Dim line As String
    Dim i As Long, col As Long, lineCount As Long, actived_line As Long

    Application.ScreenUpdating = False

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    lineCount = 0
    actived_line = 1000000000

    Do Until ts.AtEndOfStream

        line = ts.ReadLine
        lineCount = lineCount + 1

        If InStr(1, line, "END", vbBinaryCompare) > 0 Then
            actived_line = lineCount + 1
        End If

        Application.ScreenUpdating = False

        If lineCount >= actived_line Then
            col = col_header

            Do While Len(line) > 0
                ws_data.Cells(row_header, col).Value = Left(line, 16)
                line = Mid(line, 17)
                col = col + 1
            Loop

            row_header = row_header + 1
            col = col_header
        End If

    Loop

    ts.Close

    Application.ScreenUpdating = True

End Sub



Sub addTitle()

    Dim nodeid_arr As Variant, DoF_arr As Variant, CaseSet_arr As Variant
    Dim result_folderpath_arr As Variant, modeName_arr As Variant, output_arr As Variant
    Dim result_folderpath_index As Long, result_folderpath As String
    Dim modeName As String, rpm_Name As String, DofName As String, nodeidName As String
    Dim e_caseset As Variant, e_DoF As Variant, e_nodeid As Variant
    Dim lastcol As Long, c1 As Long, c2 As Long, c3 As Long
    Dim nodeid_arr_num As Long, DoF_arr_num As Long, output_arr_num As Long
    Dim CaseSet_arr_num As Long, lastcol_data As Long

    Call initWS_data

    Application.ScreenUpdating = False

    CaseSet_arr = Split(Trim(ws_tool.Range("X1")), ",")
    CaseSet_arr_num = UBound(CaseSet_arr) - LBound(CaseSet_arr) + 1

    nodeid_arr = Split(Trim(ws_tool.Range("X2")), ",")
    nodeid_arr_num = UBound(nodeid_arr) - LBound(nodeid_arr) + 1

    DoF_arr = Split(Trim(ws_tool.Range("X3")), ",")
    DoF_arr_num = UBound(DoF_arr) - LBound(DoF_arr) + 1

    output_arr = GetValuesFromRow(1, 31, 35)
    output_arr_num = UBound(output_arr) - LBound(output_arr)

    Debug.Print output_arr_num

    ws_data.Cells(2, 1) = "Model"
    ws_data.Cells(3, 1) = "RPM"
    ws_data.Cells(4, 1) = "Node ID"
    ws_data.Cells(5, 1) = "Dof"

    c1 = firstcol
    c2 = firstcol
    c3 = firstcol

    For e_caseset = LBound(CaseSet_arr) To UBound(CaseSet_arr)

        result_folderpath_index = CaseSet_arr(e_caseset) + 4
        result_folderpath = ws_tool.Range("S" & result_folderpath_index)
        result_folderpath_arr = Split(result_folderpath, "\")

        Debug.Print result_folderpath

        modeName = result_folderpath_arr(UBound(result_folderpath_arr) - 1)
        Debug.Print modeName

        modeName_arr = Split(modeName, ".")
        modeName = modeName_arr(LBound(modeName_arr))

        rpm_Name = modeName_arr(UBound(modeName_arr))

        Debug.Print rpm_Name

        ws_data.Cells(2, c3).Value = modeName
        ws_data.Cells(3, c3).Value = rpm_Name

        For e_nodeid = LBound(nodeid_arr) To UBound(nodeid_arr)

            nodeidName = nodeid_arr(e_nodeid)

            Debug.Print nodeidName

            ws_data.Cells(4, c2).Value = nodeidName

            For e_DoF = LBound(DoF_arr) To UBound(DoF_arr)

                DofName = DoF_arr(e_DoF)

                Debug.Print DofName

                ws_data.Cells(5, c1) = DofName

                c1 = c1 + output_arr_num

            Next e_DoF

            c2 = c2 + output_arr_num * DoF_arr_num

        Next e_nodeid

        c3 = c1

    Next e_caseset

    Application.ScreenUpdating = True

End Sub



Sub Clear_data()

    Application.ScreenUpdating = False

    Call initWS_data
    ws_data.Cells.ClearContents

    Application.ScreenUpdating = True

End Sub
